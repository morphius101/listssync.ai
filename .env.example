# ─────────────────────────────────────────────
# ListsSync.ai — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Node environment
NODE_ENV=development

# ── Database (Neon PostgreSQL) ────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Stripe ───────────────────────────────────
# Use sk_test_... / pk_test_... for dev, sk_live_... / pk_live_... for prod
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (Settings → Products in Stripe dashboard)
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Firebase (client-side — all VITE_ prefixed) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── SendGrid (email) ─────────────────────────
# 1. Sign up at sendgrid.com (free = 100 emails/day)
# 2. Settings → API Keys → Create (Mail Send permission)
# 3. Settings → Sender Authentication → Authenticate listssync.ai domain
#    Add the 3 CNAME records SendGrid gives you to GoDaddy DNS
SENDGRID_API_KEY=SG....

# Must match your verified sender domain in SendGrid
# After domain auth, any address @listssync.ai works
SENDGRID_FROM_EMAIL=noreply@listssync.ai
SENDGRID_FROM_NAME=ListsSync.ai

# ── Twilio (SMS) ─────────────────────────────
# 1. Sign up at twilio.com (free trial ~$15 credit)
# 2. Console → Account SID + Auth Token
# 3. Phone Numbers → Buy a number (~$1/month)
# NOTE: Free trial can only SMS verified numbers (Console → Verified Caller IDs)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ── Gemini (AI translation) ──────────────────
GEMINI_API_KEY=

# ── Google Analytics (optional) ──────────────
VITE_GA_MEASUREMENT_ID=G-...
